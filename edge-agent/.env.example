# Edge Agent Environment Variables
# Copy to .env and fill in values.
#
# Node names:  pi00-wifi  pi01-wifi  pi02-wifi  pi03-lan  pi04-lan  pi05-lan

DEVICE_ID=pi03-lan
NETWORK_TYPE=lan

# MQTT broker (control plane)
MQTT_HOST=54.198.26.122
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# Probe settings
PROBE_INTERVAL_S=10
ICMP_TARGET=54.198.26.122
ICMP_COUNT=3
ICMP_TIMEOUT_S=5
DNS_QUERY=example.com
DNS_TIMEOUT_S=5

# HTTP targets
# Primary  = health endpoint on EC2 (measures real edge→cloud path)
# Backup   = reliable public endpoint (failover target during mitigation)
HTTP_URL_PRIMARY=http://54.198.26.122:8080/health
HTTP_URL_BACKUP=http://34.226.196.133:8080/health
ACTIVE_TARGET_ID=primary
HTTP_TIMEOUT_S=10

# Bandwidth estimate (lightweight ~1MB download every N probe cycles)
BANDWIDTH_URL=https://speed.cloudflare.com/__down?bytes=1000000
BANDWIDTH_INTERVAL=30
BANDWIDTH_TIMEOUT_S=15

LOG_LEVEL=INFO
