        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "telemetry-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  time_bucket('30 seconds', ts) AS time,\n  AVG(icmp_rtt_avg_ms) as value,\n  'LAN' as metric\nFROM telemetry_measurements\nWHERE\n  $__timeFilter(ts)\n  AND icmp_ok = true\n  AND network_type = 'lan'\nGROUP BY time\nUNION ALL\nSELECT\n  time_bucket('30 seconds', ts) AS time,\n  AVG(icmp_rtt_avg_ms) as value,\n  'WiFi' as metric\nFROM telemetry_measurements\nWHERE\n  $__timeFilter(ts)\n  AND icmp_ok = true\n  AND network_type = 'wifi'\nGROUP BY time\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "LAN vs WiFi - ICMP RTT",
      "type": "timeseries"
    },
