          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  network_type,\n  ROUND(AVG(icmp_rtt_avg_ms)::numeric, 2) as avg_icmp_rtt_ms,\n  ROUND(PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY icmp_rtt_avg_ms)::numeric, 2) as p95_icmp_rtt_ms,\n  ROUND(AVG(http_latency_ms)::numeric, 2) as avg_http_latency_ms,\n  ROUND(PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY http_latency_ms)::numeric, 2) as p95_http_latency_ms,\n  ROUND(AVG(dns_latency_ms)::numeric, 2) as avg_dns_latency_ms,\n  ROUND(AVG(icmp_loss_pct)::numeric, 3) as avg_loss_pct,\n  ROUND(AVG(bandwidth_mbps)::numeric, 2) as avg_bandwidth_mbps,\n  COUNT(*) as sample_count\nFROM telemetry_measurements\nWHERE $__timeFilter(ts)\nGROUP BY network_type\nORDER BY network_type",
          "refId": "A"
        }
      ],
      "title": "Network Performance Summary",
      "type": "table"
