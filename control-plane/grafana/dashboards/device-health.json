      "id": 5,
      "options": {
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "total_messages"
          }
        ]
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "telemetry-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  device_id,\n  network_type,\n  COUNT(*) AS total_messages,\n  MIN(ts) AS first_seen,\n  MAX(ts) AS last_seen,\n  ROUND(AVG(EXTRACT(EPOCH FROM (received_ts - ts)) * 1000)::numeric, 1) AS avg_lag_ms,\n  ROUND(AVG(icmp_rtt_avg_ms)::numeric, 1) AS avg_rtt_ms,\n  ROUND(AVG(icmp_loss_pct)::numeric, 2) AS avg_loss_pct,\n  ROUND(AVG(http_latency_ms)::numeric, 1) AS avg_http_ms,\n  SUM(CASE WHEN icmp_ok = false THEN 1 ELSE 0 END) AS icmp_failures,\n  SUM(CASE WHEN dns_ok = false THEN 1 ELSE 0 END) AS dns_failures,\n  SUM(CASE WHEN http_ok = false THEN 1 ELSE 0 END) AS http_failures\nFROM telemetry_measurements\nWHERE $__timeFilter(ts)\nGROUP BY device_id, network_type\nORDER BY device_id",
          "refId": "A"
        }
      ],
      "title": "Device Summary Table",
      "type": "table",
      "description": "Summary table showing total messages, first/last seen times, and uptime per device. Quick health overview for all edge nodes."
    }
