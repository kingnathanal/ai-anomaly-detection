        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "telemetry-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(ts, '1m'),\n  device_id || ' (' || network_type || ')' AS metric,\n  AVG(EXTRACT(EPOCH FROM (received_ts - ts)) * 1000)::double precision AS value\nFROM telemetry_measurements\nWHERE $__timeFilter(ts)\nGROUP BY 1, device_id, network_type\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Ingestion Lag (received_ts - ts)",
      "type": "timeseries",
      "description": "Delay between when the edge agent generated the measurement and when the control plane received it. High lag may indicate MQTT or network congestion."
    },
    {
      "datasource": {
