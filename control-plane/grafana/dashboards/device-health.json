      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "telemetry-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(ts, '1m'),\n  device_id || ' (' || network_type || ')' AS metric,\n  COUNT(*)::double precision AS value\nFROM telemetry_measurements\nWHERE $__timeFilter(ts)\nGROUP BY 1, device_id, network_type\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Message Rate (per minute)",
      "type": "timeseries",
      "description": "Number of telemetry messages received per minute per device. Expected ~6/min with a 10s interval; drops indicate probe failures or connectivity loss."
    },
