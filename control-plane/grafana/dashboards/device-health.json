      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "telemetry-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  device_id || ' (' || network_type || ')' AS metric,\n  EXTRACT(EPOCH FROM (NOW() - MAX(ts)))::double precision AS value\nFROM telemetry_measurements\nWHERE ts > NOW() - INTERVAL '10 minutes'\nGROUP BY device_id, network_type\nORDER BY device_id",
          "refId": "A"
        }
      ],
      "title": "Time Since Last Message",
      "type": "stat",
      "description": "Seconds since the last telemetry message from each device. Values above 30s (3\u00d7 the 10s interval) suggest connectivity issues."
    },
