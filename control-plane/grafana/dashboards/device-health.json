      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "telemetry-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  device_id || ' (' || network_type || ')' AS metric,\n  CASE WHEN MAX(ts) > NOW() - INTERVAL '60 seconds' THEN 1 ELSE 0 END AS value\nFROM telemetry_measurements\nWHERE ts > NOW() - INTERVAL '5 minutes'\nGROUP BY device_id, network_type\nORDER BY device_id",
          "refId": "A"
        }
      ],
      "title": "Device Status (last 60s)",
      "type": "stat",
      "description": "Shows whether each device has reported telemetry in the last 60 seconds. Green means active; red means the device may be offline or disconnected."
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
