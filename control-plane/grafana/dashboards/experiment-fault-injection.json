          "rawSql": "SELECT\n  event_ts AS time,\n  device_id || ' (score)' as metric,\n  anomaly_score as value\nFROM anomaly_events\nWHERE $__timeFilter(event_ts)\n  AND device_id = ANY(ARRAY[$device_id])\n\nUNION ALL\n\nSELECT\n  event_ts AS time,\n  'threshold' as metric,\n  threshold as value\nFROM anomaly_events\nWHERE $__timeFilter(event_ts)\n  AND device_id = ANY(ARRAY[$device_id])\nORDER BY time",
