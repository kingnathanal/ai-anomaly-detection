      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "telemetry-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  ae.event_ts,\n  ae.device_id,\n  ae.target_id,\n  ae.is_anomaly,\n  ROUND(ae.anomaly_score::numeric, 4) as anomaly_score,\n  ROUND(ae.threshold::numeric, 4) as threshold,\n  ae.window_start_ts,\n  ae.window_end_ts,\n  ROUND(EXTRACT(EPOCH FROM (ae.window_end_ts - ae.window_start_ts))::numeric, 0) as \"window_s\",\n  ma.action as mitigation_action,\n  ma.status as mitigation_status\nFROM anomaly_events ae\nLEFT JOIN mitigation_actions ma\n  ON ma.device_id = ae.device_id\n  AND ma.issued_ts BETWEEN ae.event_ts AND ae.event_ts + INTERVAL '5 minutes'\nWHERE $__timeFilter(ae.event_ts)\n  AND ae.device_id = ANY(ARRAY[$device_id])\nORDER BY ae.event_ts DESC\nLIMIT 100",
          "refId": "A"
        }
      ],
      "title": "Detection & Mitigation Timeline",
      "description": "Correlates anomaly events with any mitigation actions taken within 5 minutes of detection.",
      "type": "table"
