      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "telemetry-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH anomaly_groups AS (\n  SELECT\n    device_id,\n    event_ts,\n    event_ts - LAG(event_ts) OVER (PARTITION BY device_id ORDER BY event_ts) as gap\n  FROM anomaly_events\n  WHERE is_anomaly = true\n    AND $__timeFilter(event_ts)\n),\nfirst_detections AS (\n  SELECT\n    device_id,\n    event_ts\n  FROM anomaly_groups\n  WHERE gap IS NULL OR gap > INTERVAL '5 minutes'\n)\nSELECT\n  AVG(EXTRACT(EPOCH FROM (fd.event_ts - prev_normal.last_normal_ts))) as value\nFROM first_detections fd\nJOIN LATERAL (\n  SELECT MAX(event_ts) as last_normal_ts\n  FROM anomaly_events ae\n  WHERE ae.device_id = fd.device_id\n    AND ae.event_ts < fd.event_ts\n    AND ae.is_anomaly = false\n) prev_normal ON true\nWHERE prev_normal.last_normal_ts IS NOT NULL",
          "refId": "A"
        }
      ],
      "title": "Avg MTTD (Mean Time to Detect)",
      "description": "Average time from last normal window to first anomaly detection in each incident.",
      "type": "stat"
    },
