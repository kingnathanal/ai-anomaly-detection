      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "telemetry-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH mitigation_windows AS (\n  SELECT\n    m.device_id,\n    m.issued_ts,\n    m.status_ts,\n    m.action,\n    m.command_id\n  FROM mitigation_actions m\n  WHERE m.status = 'applied'\n    AND m.status_ts IS NOT NULL\n    AND $__timeFilter(m.issued_ts)\n    AND m.device_id = ANY(ARRAY[$device_id])\n)\nSELECT\n  time_bucket('30s', t.ts) AS time,\n  t.device_id || ' - ICMP RTT' as metric,\n  AVG(t.icmp_rtt_avg_ms) as value\nFROM telemetry_measurements t\nWHERE $__timeFilter(t.ts)\n  AND t.device_id = ANY(ARRAY[$device_id])\n  AND EXISTS (\n    SELECT 1 FROM mitigation_windows mw\n    WHERE mw.device_id = t.device_id\n      AND t.ts BETWEEN mw.issued_ts - INTERVAL '5 minutes' AND mw.status_ts + INTERVAL '10 minutes'\n  )\nGROUP BY 1, 2\nORDER BY 1",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "telemetry-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH mitigation_windows AS (\n  SELECT\n    m.device_id,\n    m.issued_ts,\n    m.status_ts,\n    m.action,\n    m.command_id\n  FROM mitigation_actions m\n  WHERE m.status = 'applied'\n    AND m.status_ts IS NOT NULL\n    AND $__timeFilter(m.issued_ts)\n    AND m.device_id = ANY(ARRAY[$device_id])\n)\nSELECT\n  time_bucket('30s', t.ts) AS time,\n  t.device_id || ' - HTTP Latency' as metric,\n  AVG(t.http_latency_ms) as value\nFROM telemetry_measurements t\nWHERE $__timeFilter(t.ts)\n  AND t.device_id = ANY(ARRAY[$device_id])\n  AND EXISTS (\n    SELECT 1 FROM mitigation_windows mw\n    WHERE mw.device_id = t.device_id\n      AND t.ts BETWEEN mw.issued_ts - INTERVAL '5 minutes' AND mw.status_ts + INTERVAL '10 minutes'\n  )\nGROUP BY 1, 2\nORDER BY 1",
          "refId": "B"
        }
      ],
      "title": "Latency Around Mitigation Events",
      "description": "Shows ICMP RTT and HTTP latency in a window surrounding each mitigation (5 min before → 10 min after).",
      "type": "timeseries"
    },
    {
