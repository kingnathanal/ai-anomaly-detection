      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "telemetry-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  m.device_id || ' - Before' as metric,\n  AVG(t.icmp_rtt_avg_ms) as \"Avg RTT (ms)\",\n  PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY t.icmp_rtt_avg_ms) as \"P95 RTT (ms)\",\n  AVG(t.http_latency_ms) as \"Avg HTTP (ms)\",\n  AVG(t.icmp_loss_pct) as \"Avg Loss %\"\nFROM mitigation_actions m\nJOIN telemetry_measurements t\n  ON t.device_id = m.device_id\n  AND t.ts BETWEEN m.issued_ts - INTERVAL '5 minutes' AND m.issued_ts\nWHERE m.status = 'applied'\n  AND $__timeFilter(m.issued_ts)\n  AND m.device_id = ANY(ARRAY[$device_id])\nGROUP BY m.device_id\n\nUNION ALL\n\nSELECT\n  m.device_id || ' - After' as metric,\n  AVG(t.icmp_rtt_avg_ms) as \"Avg RTT (ms)\",\n  PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY t.icmp_rtt_avg_ms) as \"P95 RTT (ms)\",\n  AVG(t.http_latency_ms) as \"Avg HTTP (ms)\",\n  AVG(t.icmp_loss_pct) as \"Avg Loss %\"\nFROM mitigation_actions m\nJOIN telemetry_measurements t\n  ON t.device_id = m.device_id\n  AND t.ts BETWEEN COALESCE(m.status_ts, m.issued_ts) AND COALESCE(m.status_ts, m.issued_ts) + INTERVAL '5 minutes'\nWHERE m.status = 'applied'\n  AND $__timeFilter(m.issued_ts)\n  AND m.device_id = ANY(ARRAY[$device_id])\nGROUP BY m.device_id\n\nORDER BY metric",
          "refId": "A"
        }
      ],
      "title": "Impact Reduction: Before vs After Mitigation",
      "description": "Compares average and P95 latency in the 5 minutes before mitigation vs. 5 minutes after.",
      "type": "table"
    },
