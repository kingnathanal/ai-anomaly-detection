          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "telemetry-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH threshold_violations AS (\n  SELECT\n    time_bucket('2m', ts) as ts,\n    device_id,\n    network_type,\n    AVG(icmp_rtt_avg_ms) as avg_rtt,\n    AVG(icmp_loss_pct) as avg_loss,\n    CASE\n      WHEN network_type = 'lan' AND AVG(icmp_rtt_avg_ms) > 80 THEN true\n      WHEN network_type = 'wifi' AND AVG(icmp_rtt_avg_ms) > 110 THEN true\n      WHEN AVG(icmp_loss_pct) > 5 THEN true\n      ELSE false\n    END as threshold_alert\n  FROM telemetry_measurements\n  WHERE $__timeFilter(ts)\n  GROUP BY 1, 2, 3\n),\nml_detections AS (\n  SELECT\n    time_bucket('2m', event_ts) as ts,\n    device_id,\n    bool_or(is_anomaly) as ml_alert,\n    MAX(anomaly_score) as max_score\n  FROM anomaly_events\n  WHERE $__timeFilter(event_ts)\n  GROUP BY 1, 2\n)\nSELECT\n  tv.ts,\n  tv.device_id,\n  tv.network_type,\n  ROUND(tv.avg_rtt::numeric, 1) as avg_rtt_ms,\n  ROUND(tv.avg_loss::numeric, 2) as loss_pct,\n  tv.threshold_alert,\n  COALESCE(md.ml_alert, false) as ml_alert,\n  ROUND(md.max_score::numeric, 4) as ml_score,\n  CASE\n    WHEN tv.threshold_alert AND COALESCE(md.ml_alert, false) THEN 'Both'\n    WHEN tv.threshold_alert AND NOT COALESCE(md.ml_alert, false) THEN 'Threshold Only (ML missed)'\n    WHEN NOT tv.threshold_alert AND COALESCE(md.ml_alert, false) THEN 'ML Only (subtle anomaly)'\n    ELSE 'Normal'\n  END as detection_status\nFROM threshold_violations tv\nLEFT JOIN ml_detections md ON md.ts = tv.ts AND md.device_id = tv.device_id\nWHERE tv.threshold_alert OR COALESCE(md.ml_alert, false)\nORDER BY tv.ts DESC\nLIMIT 100",
          "refId": "A"
        }
      ],
      "title": "ML vs Threshold Detection Comparison",
      "description": "Shows windows where either the ML model or threshold alerts (or both) detected an issue. 'Threshold Only' means the ML model missed it. 'ML Only' means the model caught a subtle anomaly below threshold.",
      "type": "table"
    }
  ],
