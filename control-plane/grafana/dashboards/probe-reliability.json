      "id": 6,
      "options": {
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "total_failures" }]
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "telemetry-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  device_id,\n  network_type,\n  COUNT(*) AS total_probes,\n  SUM(CASE WHEN icmp_ok = false THEN 1 ELSE 0 END) AS icmp_failures,\n  SUM(CASE WHEN dns_ok = false THEN 1 ELSE 0 END) AS dns_failures,\n  SUM(CASE WHEN http_ok = false THEN 1 ELSE 0 END) AS http_failures,\n  SUM(CASE WHEN icmp_ok = false THEN 1 ELSE 0 END) + SUM(CASE WHEN dns_ok = false THEN 1 ELSE 0 END) + SUM(CASE WHEN http_ok = false THEN 1 ELSE 0 END) AS total_failures,\n  ROUND((100.0 * SUM(CASE WHEN icmp_ok THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0))::numeric, 2) AS icmp_success_pct,\n  ROUND((100.0 * SUM(CASE WHEN dns_ok THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0))::numeric, 2) AS dns_success_pct,\n  ROUND((100.0 * SUM(CASE WHEN http_ok THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0))::numeric, 2) AS http_success_pct\nFROM telemetry_measurements\nWHERE $__timeFilter(ts)\n  AND device_id = ANY(ARRAY[$device_id])\nGROUP BY device_id, network_type\nORDER BY total_failures DESC",
          "refId": "A"
        }
      ],
      "title": "Probe Reliability Summary",
      "type": "table"
    }
