          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(ts, '10m'),\n  device_id || ' (' || network_type || ')' AS metric,\n  (SUM(CASE WHEN icmp_ok = false THEN 1 ELSE 0 END) + SUM(CASE WHEN dns_ok = false THEN 1 ELSE 0 END) + SUM(CASE WHEN http_ok = false THEN 1 ELSE 0 END))::double precision AS value\nFROM telemetry_measurements\nWHERE $__timeFilter(ts)\n  AND device_id = ANY(ARRAY[$device_id])\nGROUP BY 1, device_id, network_type\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Total Probe Failures (stacked, per 10m)",
      "type": "timeseries"
