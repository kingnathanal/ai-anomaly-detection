          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  event_ts AS time,\n  anomaly_score as value,\n  device_id || ' (score)' as metric\nFROM anomaly_events\nWHERE\n  $__timeFilter(event_ts)\n  AND device_id = ANY(ARRAY[$device_id])\nUNION ALL\nSELECT\n  event_ts AS time,\n  threshold as value,\n  'threshold' as metric\nFROM anomaly_events\nWHERE\n  $__timeFilter(event_ts)\n  AND device_id = ANY(ARRAY[$device_id])\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Anomaly Scores Over Time",
      "type": "timeseries",
      "description": "Time series of anomaly scores from the detector, plotted per device. Scores crossing the threshold line indicate detected anomalies."
