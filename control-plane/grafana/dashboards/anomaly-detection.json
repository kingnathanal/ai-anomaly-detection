          "rawQuery": true,
          "rawSql": "SELECT\n  COUNT(*) * 1.0 / NULLIF(EXTRACT(EPOCH FROM (MAX(event_ts) - MIN(event_ts))) / 3600, 0) as value\nFROM anomaly_events\nWHERE is_anomaly = true\n  AND $__timeFilter(event_ts)",
          "refId": "A"
        }
