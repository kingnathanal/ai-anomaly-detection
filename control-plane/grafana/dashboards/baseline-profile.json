          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(ts, '2m'),\n  device_id || ' (' || network_type || ')' AS metric,\n  AVG(icmp_rtt_avg_ms)::double precision AS value\nFROM telemetry_measurements\nWHERE $__timeFilter(ts)\n  AND icmp_ok = true\n  AND device_id = ANY(ARRAY[$device_id])\nGROUP BY 1, device_id, network_type\nORDER BY 1",
