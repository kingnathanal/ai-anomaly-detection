          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  device_id,\n  network_type,\n  COUNT(*) AS samples,\n  ROUND(AVG(icmp_rtt_avg_ms)::numeric, 2) AS rtt_mean_ms,\n  ROUND(STDDEV(icmp_rtt_avg_ms)::numeric, 2) AS rtt_stddev_ms,\n  ROUND(PERCENTILE_CONT(0.50) WITHIN GROUP (ORDER BY icmp_rtt_avg_ms)::numeric, 2) AS rtt_p50_ms,\n  ROUND(PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY icmp_rtt_avg_ms)::numeric, 2) AS rtt_p95_ms,\n  ROUND(PERCENTILE_CONT(0.99) WITHIN GROUP (ORDER BY icmp_rtt_avg_ms)::numeric, 2) AS rtt_p99_ms,\n  ROUND(AVG(icmp_rtt_max_ms - icmp_rtt_min_ms)::numeric, 2) AS avg_jitter_ms,\n  ROUND(AVG(dns_latency_ms)::numeric, 2) AS dns_mean_ms,\n  ROUND(AVG(http_latency_ms)::numeric, 2) AS http_mean_ms,\n  ROUND(PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY http_latency_ms)::numeric, 2) AS http_p95_ms,\n  ROUND(AVG(icmp_loss_pct)::numeric, 3) AS avg_loss_pct\nFROM telemetry_measurements\nWHERE $__timeFilter(ts)\n  AND icmp_ok = true\n  AND device_id = ANY(ARRAY[$device_id])\nGROUP BY device_id, network_type\nORDER BY device_id",
          "refId": "A"
        }
      ],
      "title": "Baseline Statistical Profile (per device)",
