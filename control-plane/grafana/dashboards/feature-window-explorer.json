          "rawSql": "SELECT\n  event_ts AS time,\n  device_id || ' - HTTP' as metric,\n  (features->>'http_error_rate')::float as value\nFROM anomaly_events\nWHERE $__timeFilter(event_ts)\n  AND device_id = ANY(ARRAY[$device_id])\n  AND features IS NOT NULL\n  AND features->>'http_error_rate' IS NOT NULL\n\nUNION ALL\n\nSELECT\n  event_ts AS time,\n  device_id || ' - DNS' as metric,\n  (features->>'dns_failure_rate')::float as value\nFROM anomaly_events\nWHERE $__timeFilter(event_ts)\n  AND device_id = ANY(ARRAY[$device_id])\n  AND features IS NOT NULL\n  AND features->>'dns_failure_rate' IS NOT NULL\n\nORDER BY time",
          "refId": "A"
        }
      ],
