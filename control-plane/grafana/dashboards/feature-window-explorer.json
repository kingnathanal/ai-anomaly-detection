          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COUNT(*) FILTER (WHERE is_anomaly = true)::float / NULLIF(COUNT(*), 0) as value\nFROM anomaly_events\nWHERE $__timeFilter(event_ts)\n  AND device_id = ANY(ARRAY[$device_id])",
          "refId": "A"
        }
      ],
      "title": "Anomaly Rate",
      "type": "stat",
      "description": "Fraction of scored windows flagged as anomalous (0-1 scale). Baseline should be near 0; values above 0.1 during normal operation suggest model tuning is needed."
